# =============================================================================
# ERP Development Environment Configuration
# =============================================================================
# Copy this file to .env and update the values as needed
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your settings
#   docker-compose up -d
# =============================================================================

# =============================================================================
# SQL Server Configuration (Azure SQL Edge for ARM64/Apple Silicon)
# =============================================================================
MSSQL_SA_PASSWORD=YourStrong@Passw0rd
MSSQL_PORT=1433

# Connection string for the backend application
# Format: mssql+pyodbc://user:password@host:port/database?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=mssql+pyodbc://sa:YourStrong@Passw0rd@localhost:1433/ERP_ECOLED?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PASSWORD=redis_password
REDIS_PORT=6380

# Redis URL for the backend application
# Format: redis://:password@host:port/db
REDIS_URL=redis://:redis_password@localhost:6380/0

# =============================================================================
# MinIO (S3-compatible storage) Configuration
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# MinIO ports (to avoid conflicts with other services)
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011

# S3 configuration for the backend application
S3_BUCKET_NAME=erp-documents
S3_ENDPOINT_URL=http://localhost:9010
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1

# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=ERP API
APP_VERSION=1.0.0
DEBUG=true

# JWT Authentication (generate a secure key for production!)
# Use: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Business Settings
# =============================================================================
DEFAULT_CURRENCY=EUR
DEFAULT_LANGUAGE=fr
DEFAULT_WAREHOUSE_ID=1
QUOTE_VALIDITY_DAYS=30
DEFAULT_PAYMENT_TERM_DAYS=30
LOW_STOCK_THRESHOLD=10
MAX_DISCOUNT_PERCENT=50

# =============================================================================
# Email Configuration
# =============================================================================
# Email provider: ses (recommended for production), smtp, or console
EMAIL_PROVIDER=ses

# Sender configuration
EMAIL_FROM_ADDRESS=noreply@ecoled.com
EMAIL_FROM_NAME=Ecoled
# ACCOUNTING_CC_EMAIL=accounting@ecoled.com

# Global email settings
EMAIL_ENABLED=true
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=60

# =============================================================================
# AWS SES Configuration (when EMAIL_PROVIDER=ses)
# =============================================================================
# Uses AWS credentials from S3 configuration above
# SES_REGION overrides AWS_REGION for SES if needed
# SES_REGION=eu-west-1

# Optional: SES Configuration Set for tracking events (bounces, complaints, delivery)
# SES_CONFIGURATION_SET=ecoled-email-tracking

# =============================================================================
# SMTP Configuration (when EMAIL_PROVIDER=smtp)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# =============================================================================
# External Integrations (optional)
# =============================================================================

# Sage X3 Integration
# X3_API_BASE_URL=https://x3-server.example.com/api
# X3_API_KEY=your-api-key
# X3_API_SECRET=your-api-secret
# X3_ENDPOINT_NAME=MAIN
# X3_COMPANY_CODE=001
# X3_LANGUAGE=FRA

# Shopify Integration
# SHOPIFY_SHOP_DOMAIN=mystore.myshopify.com
# SHOPIFY_ACCESS_TOKEN=your-access-token
# SHOPIFY_API_VERSION=2025-01
# SHOPIFY_API_KEY=your-shopify-api-key
# SHOPIFY_API_SECRET=your-shopify-api-secret
# SHOPIFY_WEBHOOK_SECRET=your-webhook-secret
# SHOPIFY_OAUTH_CALLBACK_URL=https://yourapp.com/api/v1/integrations/shopify/callback
