                        $('#sub_searchmsg').addClass('current');
                    }
                    break;
                case 'message.aspx':
                    {
                        $('#li_msg').addClass('active');
                        $('#sub_msg').addClass('current');
                    }
                    break;
                case 'supplierorderstatus.aspx':
                    {
                        $('#li_supplierorder').addClass('active');
                        $('#sub_sodstatus').addClass('current');
                    }
                    break;
                case 'sodcinpayment.aspx':
                    {
                        $('#li_supplierorder').addClass('active');
                        $('#sub_sodcinpayment').addClass('current');
                    }
                    break;
                default:
            }
            //            GetToDoListGeneral();
            //            GetComingEventsForBasePage();

            //setInterval(GetToDoListGeneral, 5000);
            //setInterval(GetComingEventsForBasePage, 5000);
            //            GetMessage2Treate();

            //            setInterval("GetMessage2Treate()", 5000);
        } catch (e) {

        }
    }

    function shake(element, className, times) {
        var i = 0,
            t = false,
            o = element.attr("class"),
            c = "",
            timestimes = times || 2;

        if (t) return;

        t = setInterval(function () {
            i++;
            c = i % 2 ? o + ' ' + className : o;
            element.attr("class", c);

            if (i == 2 * times) {
                clearInterval(t);
                element.removeClass(className);
            }
        }, 200);
    };

    //    $(function () {
    //        shake($('.badge'), "flashRed", 10);
    //    });
</script>
