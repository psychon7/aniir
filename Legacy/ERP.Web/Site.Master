            Veuillez patienter...</p>
        <p id="message_loading_animation" class="message_loading_animation">
        </p>
    </div>
</section>
    </form>
</body>
<script>


    $("#language_sle").change(function () {
        var opt = $("#language_sle").val();
        document.cookie = "language=" + opt;

        location.reload();
    });
    if (document.cookie.indexOf("Chinese") > 0) {

        document.write("<script type='text/javascript' src='../../js/language/Chinese_Cn.js'><\/script>");
    } else if (document.cookie.indexOf("English") > 0) {

        document.write("<script type='text/javascript' src='../../js/language/English_En.js'><\/script>");
    }
    else if (document.cookie.indexOf("French") > 0) {

        document.write("<script type='text/javascript' src='../../js/language/French_Fc.js'><\/script>");
    }
    $(document).ready(setLeftMenu);

    function setLeftMenu() {
        var url = window.location.href.split('?')[0];
        var paras = url.split('/');
        var pagename = paras[paras.length - 1].toLowerCase();
        try {
            // remove all class

            switch (pagename) {
                case 'searchattproduct.aspx': // ok
                    {
                        $('#li_product').addClass('active');
                        $('#li_searchprouct_attribute').addClass('current');
                    }
                    break;
                case 'productattribute.aspx': // ok
                    {
                        $('#li_product').addClass('active');
                        $('#li_searchprouct_attribute').addClass('current');
                    }
                    break;
                case 'searchclient.aspx': // ok
                    {
                        $('#li_client').addClass('active');
                        $('#sub_searchclient').addClass('current');
