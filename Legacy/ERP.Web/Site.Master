            <!-- /NAVBAR LEFT --> 
            <!-- BEGIN TOP NAVIGATION MENU -->
            <ul class="nav navbar-nav pull-right" style="float: right;">
                <li class="dropdown" id="li-exchange"  style="float: right;">
						<a id="a_currency" class="dropdown-toggle" data-toggle="dropdown">
							€⇄$
						</a>
						<ul class="dropdown-menu inbox" id="ul_exchange" style="max-height: 800px;overflow-y: auto;">
						</ul>
					</li>
					<!-- BEGIN NOTIFICATION DROPDOWN -->	
					<li class="dropdown" id="header-notification"  style="float: right;">
						<a href="#" class="dropdown-toggle" data-toggle="dropdown">
							<i class="fa fa-calendar"></i>
							<span class="badge" id="eventbadge">0</span>
						</a>
