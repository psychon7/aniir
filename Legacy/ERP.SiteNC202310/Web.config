    <add key="DownloadTechSheetUrlSite" value="http://www.ecoled-europe.com"/>
    <add key="WithTechSheet" value="True"/>
    <add key="TechShettVersion" value="3"/>
    <!-- 2017-07-29 -->
    <!-- 票号编码格式，其他值为默认方式，4为hk方式，5为hk02方式 -->
    <add key="CodeType" value="5"/>
    <!--<add key="PdfVersion" value="0"/>-->
