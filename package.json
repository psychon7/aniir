{
  "name": "@axtech/aniir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Repo-agnostic self-healing incident runner",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "find src tests -name '*.js' -print0 | xargs -0 -n1 node --check",
    "typecheck": "node -e \"console.log('No static typecheck configured yet')\"",
    "dev": "node src/server/start.js",
    "init": "node src/cli.js init",
    "doctor": "node src/cli.js doctor",
    "sync": "node src/cli.js run-sync",
    "sync:python": "node src/cli.js run-sync --config aniir.python-fastapi.yaml",
    "sync:react": "node src/cli.js run-sync --config aniir.javascript-react.yaml",
    "sync:python:verbose": "node src/cli.js run-sync --config aniir.python-fastapi.yaml --verbose",
    "sync:react:verbose": "node src/cli.js run-sync --config aniir.javascript-react.yaml --verbose",
    "plan:python": "node src/cli.js run-sync --config aniir.python-fastapi.yaml --dry-run --verbose",
    "plan:react": "node src/cli.js run-sync --config aniir.javascript-react.yaml --dry-run --verbose",
    "incident": "node src/cli.js run-incident",
    "artifacts": "node src/cli.js generate-artifacts"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.102.0-alpha.7"
  }
}
