{
  "name": "@axtech/aniir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Repo-agnostic self-healing incident runner",
  "scripts": {
    "test": "node --test tests",
    "lint": "find src tests -name '*.js' -print0 | xargs -0 -n1 node --check",
    "typecheck": "node -e \"console.log('No static typecheck configured yet')\"",
    "dev": "node src/server/start.js",
    "incident": "node src/cli.js run-incident"
  }
}
